{
    "default": [
        {
            "type": "reject"
        }
    ],
    "transports": {
	"docker": {
        "registry.access.redhat.com": [
            {
                "type": "signedBy",
                "keyType": "GPGKeys",
                "keyPath": "/etc/pki/rpm-gpg/RPM-GPG-KEY-redhat-release"
            }
        ],
        "registry.redhat.io": [
            {
                "type": "signedBy",
                "keyType": "GPGKeys",
                "keyPath": "/etc/pki/rpm-gpg/RPM-GPG-KEY-redhat-release"
            }
        ],
        "docker.io/nostale3210": [
            {
                "type": "sigstoreSigned",
                "keyPath": "/etc/pki/containers/nostale3210.pub",
                "signedIdentity": {
                    "type": "matchRepository"
                }
            }
        ],
        "docker.io/nostale3210/ald-utils": [
            {
                "type": "sigstoreSigned",
                "keyPath": "/etc/pki/containers/nostale3210-ald.pub",
                "signedIdentity": {
                    "type": "matchRepository"
                }
            }
        ],
        "docker.io/nostale3210/hald-utils": [
            {
                "type": "sigstoreSigned",
                "keyPath": "/etc/pki/containers/nostale3210-hald.pub",
                "signedIdentity": {
                    "type": "matchRepository"
                }
            }
        ],
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "docker-daemon": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "atomic": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "containers-storage": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "dir": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "oci": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "oci-archive": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "docker-archive": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    },
    "tarball": {
        "": [
            {
                "type": "insecureAcceptAnything"
            }
        ]
    }
    }
}
